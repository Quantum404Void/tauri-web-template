{
  "name": "tauri-web-template",
  "version": "1.0.0",
  "description": "Tauri 2 + Vue 3 + TypeScript dual-mode (desktop + web) application template",
  "license": "MIT",
  "author": "Wang Yu",
  "type": "module",
  "scripts": {
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "vp run typecheck:node && vp run typecheck:web",
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "vp run typecheck && tauri build",
    "build:tauri": "tauri build",
    "build:web": "vite build",
    "preview:web": "vite preview",
    "build:analyze": "VITE_ANALYZE=true vite build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-autostart": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.3.0",
    "@tauri-apps/plugin-fs": "^2.4.2",
    "@tauri-apps/plugin-opener": "^2.4.0",
    "@tauri-apps/plugin-os": "^2.3.0",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "@tauri-apps/plugin-window-state": "^2.4.0",
    "@vueuse/core": "^14.3.0",
    "jszip": "^3.10.1",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@tauri-apps/cli": "^2.5.0",
    "@types/node": "^25.7.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "rollup-plugin-visualizer": "^6.0.11",
    "sass-embedded": "^1.99.0",
    "typescript": "5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plus": "^0.1.20",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@tauri-apps/cli"
  ]
}
