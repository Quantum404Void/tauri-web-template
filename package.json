{
  "name": "tauri-web-template",
  "version": "1.0.0",
  "description": "Tauri 2 + Vue 3 + TypeScript dual-mode (desktop + web) application template",
  "license": "MIT",
  "author": "Wang Yu",
  "type": "module",
  "scripts": {
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "typecheck": "vp check --no-fmt --no-lint",
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "vp run typecheck && tauri build",
    "build:tauri": "tauri build",
    "build:web": "vite build",
    "preview:web": "vite preview",
    "build:analyze": "VITE_ANALYZE=true vite build"
  },
  "dependencies": {
    "@open-file-viewer/core": "^0.1.18",
    "@open-file-viewer/vue": "^0.1.18",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@vueuse/core": "^14.3.0",
    "jszip": "^3.10.1",
    "naive-ui": "^2.44.1",
    "pdfjs-dist": "^6.1.200",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.100.0",
    "typescript": "^7.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.4",
    "vite-plugin-mkcert": "^2.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vite-plus": "^0.2.4"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@tauri-apps/cli"
  ]
}
