{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tauri Vue Template",
  "version": "1.0.0",
  "identifier": "com.tauri.vue.template",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:26888",
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "Tauri Vue Template",
        "width": 1024,
        "height": 680,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https://tauri.localhost https://updates.example.com; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 Wang Yu",
    "category": "DeveloperTool",
    "shortDescription": "Tauri + Vue3 template",
    "longDescription": "A production-ready Tauri 2 + Vue3 desktop application template."
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
